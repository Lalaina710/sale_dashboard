<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Catégorie du module -->
    <record id="module_category_sale_dashboard" model="ir.module.category">
        <field name="name">Dashboard Vente</field>
        <field name="sequence">50</field>
    </record>

    <!-- Groupe Utilisateur Dashboard Vente -->
    <record id="group_sale_dashboard_user" model="res.groups">
        <field name="name">Utilisateur Dashboard Vente</field>
        <field name="category_id" ref="module_category_sale_dashboard"/>
    </record>

    <!-- Groupe Responsable Dashboard Vente (hérite de Utilisateur) -->
    <record id="group_sale_dashboard_manager" model="res.groups">
        <field name="name">Responsable Dashboard Vente</field>
        <field name="category_id" ref="module_category_sale_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('group_sale_dashboard_user'))]"/>
    </record>

    <!-- Les responsables des ventes obtiennent automatiquement le rôle Responsable Dashboard -->
    <record id="sales_team.group_sale_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_sale_dashboard_manager'))]"/>
    </record>
</odoo>
