<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_dashboard_config_form" model="ir.ui.view">
        <field name="name">sale.dashboard.config.form</field>
        <field name="model">sale.dashboard.config</field>
        <field name="arch" type="xml">
            <form string="Configuration Dashboard Ventes">
                <sheet>
                    <group>
                        <group string="Paramètres d'affichage">
                            <field name="chart_days"/>
                            <field name="recent_days"/>
                            <field name="active_order_limit"/>
                        </group>
                        <group string="Comportement">
                            <field name="auto_refresh_interval"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sale_dashboard_config_list" model="ir.ui.view">
        <field name="name">sale.dashboard.config.list</field>
        <field name="model">sale.dashboard.config</field>
        <field name="arch" type="xml">
            <list string="Configurations Dashboard">
                <field name="name"/>
                <field name="chart_days"/>
                <field name="recent_days"/>
                <field name="auto_refresh_interval"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_sale_dashboard_config" model="ir.actions.act_window">
        <field name="name">Configuration Dashboard</field>
        <field name="res_model">sale.dashboard.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_sale_dashboard_config"
        name="Config. Dashboard"
        parent="sale.menu_sale_config"
        action="action_sale_dashboard_config"
        sequence="100"
        groups="sale_dashboard.group_sale_dashboard_manager"/>
</odoo>
